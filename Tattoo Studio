function renderHistory(){
  const c=document.getElementById("history-list");
  document.getElementById("history-count").innerText=history.length+" Saved Runs";
  if(!history.length){c.innerHTML="<div class='empty'>◉ Archive memory banks are empty.</div>";return;}
  c.innerHTML="";
  history.forEach(h=>{
    const div=document.createElement("div"); div.className="history-card"; div.style.borderColor=G[h.primary]?.color+"40";
    div.innerHTML=`<div style="display:flex;justify-content:between;font-size:10px;font-family:monospace;color:#555"><span>${h.date} — ${h.type}</span><span style="margin-left:auto;color:${G[h.primary]?.color}">${G[h.primary]?.symbol} ${h.primary}</span></div><div style="font-size:13px;font-weight:600;margin:4px 0;color:#e0e0f0">${h.concept}</div><p style="font-size:11px;color:#777;font-family:serif;font-style:italic">${h.prompt.slice(0,140)}...</p>`;
    c.appendChild(div);
  });
}
function clearHistory(){ history=[]; localStorage.removeItem("ge-history"); renderHistory(); }
function resetTab(prefix){ document.getElementById(prefix+"-input").value=""; document.getElementById(prefix+"-chars").innerText="0 chars"; document.getElementById(prefix+"-guardian-row").innerHTML=""; document.getElementById(prefix+"-phases").innerHTML=""; document.getElementById(prefix+"-final").innerHTML=""; document.getElementById(prefix+"-error").innerHTML=""; }
