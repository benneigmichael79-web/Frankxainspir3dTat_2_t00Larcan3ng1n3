  const btn=document.getElementById("flash-btn");
  if(!theme){res.innerHTML=`<div class="error-box">✕ Enter a theme for the Flash Sheet.</div>`;return;}
  btn.disabled=true; res.innerHTML="<div class='empty'>⬡ Designing flash matrix coordinates...</div>";
  await new Promise(r=>setTimeout(r,1800));
  res.innerHTML="";
  const sty=document.getElementById("flash-style").value;
  const styNote=sty?` [${sty.toUpperCase()} STYLE]`:"";
  
  for(let i=1; i<=8; i++){
    const div=document.createElement("div"); div.className="concept-card"; div.style.borderColor=activeColor+"40";
    div.innerHTML=`<div class="concept-num" style="color:${activeColor}">Flash Segment #0${i}</div><div class="concept-title">Design Target Option ${i}</div><div class="concept-prompt">${theme}, individual flash sheet icon, bold outlines, sticker design format, high contrast ink work${styNote}. Segment element reference coordinate v0${i} --v 6.0</div>`;
    res.appendChild(div);
  }
  btn.disabled=false;
}

