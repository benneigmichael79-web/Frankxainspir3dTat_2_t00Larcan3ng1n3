  c.appendChild(div);
}

function renderFinal(containerId, primary, secondary, prompt, sigils, stencilTgt, style, placement){
  const pg=G[primary];
  const isStencil=stencilTgt&&stencilTgt!=="";
  document.getElementById(containerId).innerHTML=`
    <div class="final-box" style="border:1px solid ${pg.color};background:linear-gradient(135deg,${pg.color}08,#0d0d17)">
      <div class="final-label" style="color:${pg.color}">${pg.sigil} ${isStencil?"Stencil Prompt — "+stencilTgt:"Final Transmission — Pipeline Complete"}</div>
      ${style?`<div style="font-size:10px;color:#555;font-family:monospace;margin-bottom:10px">STYLE: ${style} | PLACEMENT: ${placement||"—"}</div>`:""}
      <div class="final-prompt" style="border-left-color:${pg.color}">${prompt}</div>
      <div class="final-sigil">${sigils}</div>
      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px">
        <span class="tag-chip" style="border:1px solid ${pg.color}60;color:${pg.color}">${pg.symbol} ${primary} · ${pg.element}</span>
        <span class="tag-chip" style="border:1px solid ${G[secondary].color}60;color:${G[secondary].color}">${G[secondary].symbol} ${secondary} · ${G[secondary].element}</span>
      </div>
      <div style="display:flex;gap:8px;flex-wrap:wrap">
        <button class="btn btn-filled" onclick="copyText(this,'${prompt.replace(/'/g,"\\'")}','Copied!')" style="--ac:${pg.color};--ac88:${pg.color}88">⎘ COPY PROMPT</button>
        <button class="btn btn-outline" onclick="downloadTxt()" style="--ac:${pg.color}">⬇ DOWNLOAD</button>
      </div>
    </div>`;
  window._lastOutput={primary,secondary,prompt,sigils,style,placement};
}

function copyText(btn, txt, doneMsg){
  navigator.clipboard.writeText(txt).then(()=>{
    const old=btn.innerText; btn.innerText=doneMsg;
    setTimeout(()=>btn.innerText=old,2000);
  });
}

function downloadTxt(){
  if(!window._lastOutput) return;
  const o=window._lastOutput;
  const content=`ARCANEA TRANSMISSION\n====================\nPrimary: ${o.primary}\nSecondary: ${o.secondary}\nStyle: ${o.style||"None"}\nPlacement: ${o.placement||"None"}\n\nPROMPT:\n${o.prompt}\n\nSIGILS:\n${o.sigils}`;
  const blob=new Blob([content],{type:"text/plain"});
  const a=document.createElement("a"); a.href=URL.createObjectURL(blob); a.download="arcanea-prompt.txt"; a.click();
}

async function runPipelineFlow(prefix, input, isStudio){
  const err=document.getElementById(prefix+"-error"); err.innerHTML="";
  const phasesDiv=document.getElementById(prefix+"-phases"); phasesDiv.innerHTML="";
  const finalDiv=document.getElementById(prefix+"-final"); finalDiv.innerHTML="";
  document.getElementById(prefix+"-guardian-row").innerHTML="";
  
  if(!input.trim()){err.innerHTML=`<div class="error-box">✕ Error: Input prompt channel is empty. Enter an intent or vision.</div>`;return;}
  
  let pSel="", sSel="", sty="", plc="";
  if(isStudio){
    pSel=document.getElementById("lock-primary").value;
    sSel=document.getElementById("lock-secondary").value;
    sty=document.getElementById("studio-style").value;
    plc=document.getElementById("studio-placement").value;
  }
  
  const bInvoke=document.getElementById(prefix+"-invoke-btn"); bInvoke.disabled=true;
  const {primary,secondary}=pickGuardians(input, pSel, sSel);
  const pc=G[primary].color;
  setColor(pc);
  buildDots(prefix+"-dots",pc);
  
  const phaseOutputs=generatePhases(input, primary, secondary, sty, plc, artistVoice, isStudio, stencilTarget);
  
  for(let i=0; i<PHASES.length; i++){
    setDot(prefix,i,"active",pc);
    await new Promise(r=>setTimeout(r,Math.random()*400+250));
    setDot(prefix,i,"done",pc);
    if(i===1) renderGuardians(prefix+"-guardian-row",primary,secondary);
    renderPhaseCard(prefix+"-phases",PHASES[i],phaseOutputs[i],pc);
  }
  
  const finalPrompt=phaseOutputs[4];
  const sigils=phaseOutputs[5];
  renderFinal(prefix+"-final",primary,secondary,finalPrompt,sigils,stencilTarget,sty,plc);
  
  const savedRun={id:Date.now(),date:new Date().toLocaleDateString(),type:isStudio?"Studio":"Pipeline",concept:input,primary,secondary,prompt:finalPrompt};
  history.unshift(savedRun);
  if(history.length>30) history.pop();
  localStorage.setItem("ge-history",JSON.stringify(history));
  
  bInvoke.disabled=false;
}

function runOriginal(){ runPipelineFlow("orig",document.getElementById("orig-input").value,false); }
function runStudio(){ runPipelineFlow("studio",document.getElementById("studio-input").value,true); }

async function runFlash(){
  const theme=document.getElementById("flash-theme").value.trim();
