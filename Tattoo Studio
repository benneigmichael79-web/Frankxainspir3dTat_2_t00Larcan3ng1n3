document.getElementById("orig-input").addEventListener("input",e=>document.getElementById("orig-chars").innerText=e.target.value.length+" chars");
document.getElementById("studio-input").addEventListener("input",e=>document.getElementById("studio-chars").innerText=e.target.value.length+" chars");

function pickGuardians(input, lockedP, lockedS){
  let primary=lockedP, secondary=lockedS;
  if(!primary||!G[primary]){
    const lower=input.toLowerCase();
    if(lower.match(/fire|sun|bold|bright|power|strength|lion/)) primary="Solaris";
    else if(lower.match(/water|ocean|flow|dream|moon|emotion|feeling/)) primary="Lunara";
    else if(lower.match(/earth|tree|grow|nature|root|stable|family/)) primary="Sylvanus";
    else if(lower.match(/wind|air|thought|mind|idea|swift|connect/)) primary="Aethon";
    else if(lower.match(/dark|void|transform|shadow|death|skull|rebirth|change/)) primary="Pyraxis";
    else primary=GKEYS[Math.floor(Math.random()*5)];
  }
  if(!secondary||!G[secondary]||secondary===primary){
    const remaining=GKEYS.filter(k=>k!==primary);
    secondary=remaining[Math.floor(Math.random()*remaining.length)];
  }
  return {primary,secondary};
}

function generatePhases(input, primary, secondary, style, placement, voice, isStudio, stencilTgt){
  const pg=G[primary], sg=G[secondary];
  const styleNote=style?` in ${style} style`:"";
  const placeNote=placement?` on the ${placement}`:"";
  const p1=`The content carries a deep current of ${pg.element.toLowerCase()} and ${sg.element.toLowerCase()} energy. Dominant themes: ${pg.keys[0]} tension meeting ${sg.keys[0]} resolution. The emotional register is ${pg.keys[1]} and ${sg.keys[2]}, with a primary transformation arc from constraint toward liberation. The mythic archetype present is ${pg.archetype} in dialogue with ${sg.archetype} — a pairing that generates rare alchemical depth.`;
  const p2=`Primary: ${primary} (${pg.element})\nSecondary: ${secondary} (${sg.element})\n\nRationale: The content's ${pg.keys[0]} nature calls for ${primary}'s ${pg.archetype} energy, while ${secondary} provides the ${sg.keys[2]} counterweight needed to achieve balance and depth.${guardianLockOn?"\n[Guardian Locked by Artist]":""}`;
  const p3=`Primary hue: ${pg.element === "Fire" ? "deep amber burning into obsidian" : pg.element === "Water" ? "deep teal dissolving into silver" : pg.element === "Earth" ? "forest green grounding into warm ochre" : pg.element === "Air" ? "violet mist shifting into pale silver" : "void black bleeding into electric rose"}. Secondary resonance: ${sg.color} as counterpoint, creating tension and harmony simultaneously.\nMotifs: ${pg.keys[2]} geometry intersecting ${sg.keys[1]} organic form. Texture: ${pg.element.toLowerCase()}-forged, ${sg.element.toLowerCase()}-tempered.`;
  const p4=`This mark carries the ancient story of ${pg.archetype} meeting ${sg.archetype} — where ${pg.element.toLowerCase()} and ${sg.element.toLowerCase()} negotiate a treaty written in ink.\n\nThe tension: ${input.slice(0,60)}${input.length>60?"...":""} — a threshold moment.\nThe transformation: from what was into what must become.\nWhat this tattoo will carry on the skin forever: the moment the ${pg.element.toLowerCase()} chose to flow, and the ${sg.element.toLowerCase()} chose to burn.`;
  let p5;
  if(isStudio && stencilTgt && STENCIL_FORMATS[stencilTgt]){
    const basePrompt = `${input}${styleNote}${placeNote}. ${pg.archetype} meets ${sg.archetype}. ${pg.element} and ${sg.element} elements. ${pg.keys[0]} energy with ${sg.keys[1]} depth`;
    p5 = STENCIL_FORMATS[stencilTgt](basePrompt);
  } else {
    p5=`${pg.keys[0].charAt(0).toUpperCase()+pg.keys[0].slice(1)} and ${sg.keys[1]}, the composition breathes between worlds — ${input}${styleNote}${placeNote}. Bold mythic lines carry the weight of ${pg.element.toLowerCase()} while ${sg.element.toLowerCase()} softens the edges into something that moves. ${voice?`Artist voice: ${voice.slice(0,80)}... `:""} Elegant negative space as sacred silence. A design that earns its place on the body and keeps earning it every decade after.`;
  }
  const p6=`SIGIL: ${pg.sigil} ${primary} × ${secondary} ${sg.sigil} — where ${pg.element} meets ${sg.element}, the mark holds\nACCENT: ${isStudio?`${style||"Bold"} weight anchoring fine detail work. Negative space as breathing room. ${placement||"Placement"} composition flows with natural body contour.`:`Deep anchor lines softening to fine detail. Color temperature shifts from warm to cool. Sacred geometry as underlying structure.`}\nTAG: ${pg.element} · ${sg.element} · ${pg.keys[0]}`;
  const score1=Math.floor(Math.random()*2)+8;
  const score2=Math.floor(Math.random()*2)+8;
  const p7=`ORACLE: ${score1}/10 — ${isStudio?"Tattoo design viability confirmed — will translate powerfully to skin":"Clear, purposeful, strategically sound"}\nARCANEA: ${score2}/10 — Genuine mythic depth achieved, ${pg.archetype} and ${sg.archetype} pairing produces rare resonance\nSYNTHESIS: The ${primary} and ${secondary} pairing generates ${pg.element.toLowerCase()}-${sg.element.toLowerCase()} alchemy rarely achieved. This design will carry meaning across decades of wear.\nVERDICT: This mark is ready to be made permanent.`;
  return [p1,p2,p3,p4,p5,p6,p7];
}

function buildDots(containerId, color){
  const c=document.getElementById(containerId); c.innerHTML="";
  PHASES.forEach((p,i)=>{
    const d=document.createElement("div"); d.className="dot"; d.id=containerId+"-dot-"+i;
    d.innerText=p.icon; d.style.color="#333"; d.style.borderColor="#222"; d.title=p.label;
    c.appendChild(d);
  });
}
function setDot(containerId,i,state,color){
  const d=document.getElementById(containerId+"-dot-"+i); if(!d) return;
  if(state==="active"){d.style.color=color;d.style.borderColor=color;d.style.background=color+"22";d.style.animation="shimmer 1s infinite";}
  else if(state==="done"){d.innerText="✓";d.style.color=color;d.style.borderColor=color;d.style.background=color+"22";d.style.animation="none";}
}

function renderGuardians(containerId, primary, secondary){
  const pg=G[primary], sg=G[secondary];
  document.getElementById(containerId).innerHTML=`
    <div class="guardian-row">
      <div class="guardian-badge" style="background:${pg.color}12;border-color:${pg.color}40">
        <div class="gs">${pg.symbol}</div>
        <div class="gr" style="color:${pg.secondary}">Primary Guardian</div>
        <div class="gn" style="color:${pg.color}">${primary}</div>
        <div class="gd">${pg.domain}</div>
      </div>
      <div class="guardian-badge" style="background:${sg.color}12;border-color:${sg.color}40">
        <div class="gs">${sg.symbol}</div>
